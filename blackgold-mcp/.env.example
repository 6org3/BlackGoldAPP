# Copia este archivo a .env (gitignored) y completa los valores reales.
# Nunca commitear .env ni pegar estas claves en un chat.

SUPABASE_URL=

# Desde la migración v24 (RLS real) la anon key no tiene acceso a tablas.
# Este servidor corre solo en la máquina del staff, así que usa la
# service_role key (Supabase → Settings → API → service_role). NUNCA
# usar esta clave en Dashboard_Premium ni en ningún código que llegue
# al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Legado (ya no alcanza para las tools, se acepta solo como fallback):
SUPABASE_ANON_KEY=
